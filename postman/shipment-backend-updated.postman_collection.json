              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "commission-rules"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "search",
                  "value": ""
                },
                {
                  "key": "layer",
                  "value": "Marine Agent"
                },
                {
                  "key": "routeFrom",
                  "value": "{{portId1}}"
                },
                {
                  "key": "routeTo",
                  "value": "{{portId2}}"
                },
                {
                  "key": "partnerScope",
                  "value": "AllChildPartners"
                }
              ]
            },
            "description": "List all active commission rules with filtering by layer, routes, and partner scope."
          },
          "response": []
