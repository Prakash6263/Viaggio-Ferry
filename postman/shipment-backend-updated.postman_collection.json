{
  "info": {
    "name": "Shipment Backend - Rules API",
    "description": "API endpoints for Markup/Discount Rules and Commission Rules with multi-route support",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Markup/Discount Rules",
      "description": "Endpoints for managing markup and discount rules with multiple route support",
      "item": [
        {
          "name": "Create Markup/Discount Rule",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ruleName\": \"5% Markup for Passenger Service\",\n  \"provider\": \"{{providerId}}\",\n  \"providerType\": \"Company\",\n  \"appliedLayer\": \"Company\",\n  \"partnerScope\": \"AllChildPartners\",\n  \"ruleType\": \"Markup\",\n  \"ruleValue\": 5,\n  \"valueType\": \"percentage\",\n  \"routes\": [\n    {\n      \"routeFrom\": \"{{portId1}}\",\n      \"routeTo\": \"{{portId2}}\"\n    },\n    {\n      \"routeFrom\": \"{{portId3}}\",\n      \"routeTo\": \"{{portId4}}\"\n    }\n  ],\n  \"serviceDetails\": {\n    \"passenger\": [\n      {\n        \"cabinId\": \"{{cabinId}}\"\n      }\n    ],\n    \"cargo\": [],\n    \"vehicle\": []\n  },\n  \"effectiveDate\": \"2024-01-15T00:00:00Z\",\n  \"expiryDate\": \"2024-12-31T23:59:59Z\",\n  \"priority\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/markup-discounts",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "markup-discounts"
              ]
            },
            "description": "Create a new markup/discount rule. Supports multiple routes per rule."
          },
          "response": []
        },
        {
          "name": "List Markup/Discount Rules",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/markup-discounts?page=1&limit=10&search=&layer=Company&routeFrom={{portId1}}&routeTo={{portId2}}&ruleType=Markup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "markup-discounts"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "search",
                  "value": ""
                },
                {
                  "key": "layer",
                  "value": "Company"
                },
                {
                  "key": "routeFrom",
                  "value": "{{portId1}}"
                },
                {
                  "key": "routeTo",
                  "value": "{{portId2}}"
                },
                {
                  "key": "ruleType",
                  "value": "Markup"
                }
              ]
            },
            "description": "List all active markup/discount rules with filtering by layer, route, and rule type."
          },
          "response": []
        },
        {
          "name": "Get Markup/Discount Rule by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/markup-discounts/{{ruleId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "markup-discounts",
                "{{ruleId}}"
              ]
            },
            "description": "Get a specific markup/discount rule by ID including all route details."
          },
          "response": []
        },
        {
          "name": "Update Markup/Discount Rule",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ruleName\": \"Updated 5% Markup for Passenger Service\",\n  \"ruleValue\": 7,\n  \"routes\": [\n    {\n      \"routeFrom\": \"{{portId1}}\",\n      \"routeTo\": \"{{portId2}}\"\n    },\n    {\n      \"routeFrom\": \"{{portId3}}\",\n      \"routeTo\": \"{{portId4}}\"\n    },\n    {\n      \"routeFrom\": \"{{portId5}}\",\n      \"routeTo\": \"{{portId6}}\"\n    }\n  ],\n  \"effectiveDate\": \"2024-01-15T00:00:00Z\",\n  \"expiryDate\": \"2024-12-31T23:59:59Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/markup-discounts/{{ruleId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "markup-discounts",
                "{{ruleId}}"
              ]
            },
            "description": "Update an existing markup/discount rule. Can update routes array with multiple routes."
          },
          "response": []
        },
        {
          "name": "Delete Markup/Discount Rule",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/markup-discounts/{{ruleId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "markup-discounts",
                "{{ruleId}}"
              ]
            },
            "description": "Soft delete a markup/discount rule."
          },
          "response": []
        },
        {
          "name": "Get Markup/Discount Rule History",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/markup-discounts/history?ruleId={{ruleId}}&actionType=Created&dateRange=last30days",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "markup-discounts",
                "history"
              ],
              "query": [
                {
                  "key": "ruleId",
                  "value": "{{ruleId}}"
                },
                {
                  "key": "actionType",
                  "value": "Created"
                },
                {
                  "key": "dateRange",
                  "value": "last30days"
                }
              ]
            },
            "description": "Get history of markup/discount rule actions with filters for specific rules and date ranges."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Commission Rules",
      "description": "Endpoints for managing commission rules with multiple route support",
      "item": [
        {
          "name": "Create Commission Rule",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ruleName\": \"10% Commission for Marine Agents\",\n  \"provider\": \"{{providerId}}\",\n  \"providerType\": \"Company\",\n  \"appliedLayer\": \"Marine Agent\",\n  \"partnerScope\": \"AllChildPartners\",\n  \"commissionType\": \"percentage\",\n  \"commissionValue\": 10,\n  \"routes\": [\n    {\n      \"routeFrom\": \"{{portId1}}\",\n      \"routeTo\": \"{{portId2}}\"\n    },\n    {\n      \"routeFrom\": \"{{portId3}}\",\n      \"routeTo\": \"{{portId4}}\"\n    }\n  ],\n  \"serviceDetails\": {\n    \"passenger\": [\n      {\n        \"cabinId\": \"{{cabinId}}\"\n      }\n    ],\n    \"cargo\": [],\n    \"vehicle\": []\n  },\n  \"effectiveDate\": \"2024-01-15T00:00:00Z\",\n  \"expiryDate\": \"2024-12-31T23:59:59Z\",\n  \"priority\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/commission-rules",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "commission-rules"
              ]
            },
            "description": "Create a new commission rule. Supports multiple routes per rule."
          },
          "response": []
        },
