            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ruleName\": \"Updated 15% Commission for Marine Agents\",\n  \"commissionValue\": 15,\n  \"routes\": [\n    {\n      \"routeFrom\": \"{{portId1}}\",\n      \"routeTo\": \"{{portId2}}\"\n    },\n    {\n      \"routeFrom\": \"{{portId3}}\",\n      \"routeTo\": \"{{portId4}}\"\n    },\n    {\n      \"routeFrom\": \"{{portId5}}\",\n      \"routeTo\": \"{{portId6}}\"\n    }\n  ],\n  \"effectiveDate\": \"2024-01-15T00:00:00Z\",\n  \"expiryDate\": \"2024-12-31T23:59:59Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/commission-rules/{{commissionRuleId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
