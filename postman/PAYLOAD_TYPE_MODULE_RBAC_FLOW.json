    {
      "name": "PASSENGER TYPES",
      "item": [
        {
          "name": "Create Passenger Type",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Payload created successfully', function () {",
                  "  var jsonData = pm.response.json();",
                  "  pm.expect(jsonData.success).to.be.true;",
                  "  pm.expect(jsonData.data.payloadType._id).to.be.a('string');",
                  "  pm.environment.set('payloadTypeId', jsonData.data.payloadType._id);",
                  "});",
                  "",
                  "pm.test('Category is passenger', function () {",
                  "  var jsonData = pm.response.json();",
                  "  pm.expect(jsonData.data.payloadType.category).to.equal('passenger');",
                  "});",
                  "",
                  "pm.test('ageRange field exists with numeric format', function () {",
                  "  var jsonData = pm.response.json();",
                  "  pm.expect(jsonData.data.payloadType.ageRange).to.be.an('object');",
                  "  pm.expect(jsonData.data.payloadType.ageRange.from).to.equal(18);",
                  "  pm.expect(jsonData.data.payloadType.ageRange.to).to.equal(65);",
                  "});",
                  "",
                  "pm.test('createdBy has correct structure (company or user type)', function () {",
                  "  var jsonData = pm.response.json();",
                  "  pm.expect(jsonData.data.payloadType.createdBy.type).to.be.oneOf(['company', 'user']);",
                  "  pm.expect(jsonData.data.payloadType.createdBy.id).to.exist;",
                  "  pm.expect(jsonData.data.payloadType.createdBy.name).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
