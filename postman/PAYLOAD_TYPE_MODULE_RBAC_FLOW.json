              "raw": "{\n  \"name\": \"Adult Passenger\",\n  \"code\": \"ADT\",\n  \"description\": \"Standard adult passenger\",\n  \"category\": \"passenger\",\n  \"ageRange\": {\n    \"from\": 18,\n    \"to\": 65\n  },\n  \"status\": \"Active\"\n}"
            },
