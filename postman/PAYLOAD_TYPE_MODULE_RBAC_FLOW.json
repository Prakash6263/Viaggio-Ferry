    {
      "name": "PASSENGER TYPES",
      "item": [
        {
          "name": "Create Passenger Type",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response contains success flag', function () {",
                  "  var jsonData = pm.response.json();",
                  "  pm.expect(jsonData.success).to.be.true;",
                  "});",
                  "",
                  "pm.test('Payload type created with correct category', function () {",
                  "  var jsonData = pm.response.json();",
                  "  pm.expect(jsonData.data.payloadType.category).to.equal('passenger');",
                  "  pm.expect(jsonData.data.payloadType.ageRange).to.not.be.null;",
                  "  pm.expect(jsonData.data.payloadType.maxWeight).to.be.null;",
                  "  pm.expect(jsonData.data.payloadType.dimensions).to.be.null;",
                  "});",
                  "",
                  "pm.test('Verify createdBy audit field', function () {",
                  "  var jsonData = pm.response.json();",
                  "  pm.expect(jsonData.data.payloadType.createdBy).to.have.property('id');",
                  "  pm.expect(jsonData.data.payloadType.createdBy).to.have.property('type');",
                  "  pm.expect(['company', 'user']).to.include(jsonData.data.payloadType.createdBy.type);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "pm.environment.set('payloadTypeId', jsonData.data.payloadType._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
