        {
          "name": "List All Rules",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.test('Rules retrieved successfully', function() {",
                  "        pm.expect(jsonData.success).to.equal(true);",
                  "        pm.expect(jsonData.data).to.be.an('array');",
                  "        pm.expect(jsonData.pagination).to.exist;",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/markup-discounts?page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "markup-discounts"],
              "query": [
                {
                  "key": "page",
