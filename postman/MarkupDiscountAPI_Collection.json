{
  "info": {
    "_postman_id": "markup-discount-api-collection",
    "name": "Markup & Discount Rules API",
    "description": "Complete API collection for managing Markup and Discount Rules in the Ferry Booking Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Markup Discount APIs",
      "item": [
        {
          "name": "Create Markup Rule - Passenger",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('ruleId', jsonData.data._id);",
                  "    pm.test('Rule created successfully', function() {",
                  "        pm.expect(jsonData.success).to.equal(true);",
                  "        pm.expect(jsonData.data.ruleName).to.exist;",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ruleName\": \"Passenger Economy Markup\",\n  \"provider\": \"{{partnerId}}\",\n  \"providerType\": \"Partner\",\n  \"appliedLayer\": \"Commercial\",\n  \"partnerScope\": \"AllChildPartners\",\n  \"ruleType\": \"Markup\",\n  \"ruleValue\": 10,\n  \"valueType\": \"percentage\",\n  \"serviceDetails\": {\n    \"passenger\": [\n      {\n        \"cabinId\": \"{{cabin_economy}}\"\n      }\n    ],\n    \"cargo\": [],\n    \"vehicle\": []\n  },\n  \"routeFrom\": \"{{port_id_1}}\",\n  \"routeTo\": \"{{port_id_2}}\",\n  \"effectiveDate\": \"2026-03-01T00:00:00Z\",\n  \"expiryDate\": \"2026-12-31T00:00:00Z\",\n  \"priority\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/markup-discounts",
              "host": ["{{base_url}}"],
              "path": ["api", "markup-discounts"]
            }
          },
          "response": []
        },
