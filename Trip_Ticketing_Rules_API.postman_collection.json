              "mode": "raw",
              "raw": "{\n  \"ticketingRules\": [\n    {\n      \"ruleType\": \"REFUND\",\n      \"rule\": \"{{rule_id}}\"\n    },\n    {\n      \"ruleType\": \"VOID\",\n      \"rule\": \"rule_id_2\"\n    },\n    {\n      \"ruleType\": \"REISSUE\",\n      \"rule\": \"rule_id_3\"\n    }\n  ]\n}"
