      "name": "AUTH — CABIN FLOW",
      "item": [
        {
          "name": "Company Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const responseData = pm.response.json();",
                  "    pm.environment.set('token', responseData.data.token);",
                  "    pm.environment.set('companyId', responseData.data.company._id);",
                  "    console.log('[v0] Company token set:', responseData.data.token.substring(0, 20) + '...');",
                  "} else {",
                  "    console.error('[v0] Login failed:', pm.response.text());",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"company@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
