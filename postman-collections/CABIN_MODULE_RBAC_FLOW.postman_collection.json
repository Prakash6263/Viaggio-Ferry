    {
      "name": "PASSENGER CABINS",
      "item": [
        {
          "name": "Create Passenger Cabin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "    const responseData = pm.response.json();",
                  "    const cabin = responseData.data.cabin;",
                  "    pm.environment.set('passengerCabinId', cabin._id);",
                  "    ",
                  "    // Validate response structure",
                  "    pm.test('Response has correct structure', () => {",
                  "        pm.expect(cabin).to.have.property('_id');",
                  "        pm.expect(cabin).to.have.property('name');",
                  "        pm.expect(cabin).to.have.property('type');",
                  "        pm.expect(cabin).to.have.property('createdBy');",
                  "    });",
                  "    ",
                  "    // Validate audit fields",
                  "    pm.test('Audit fields are populated', () => {",
                  "        pm.expect(cabin.createdBy).to.have.property('type');",
                  "        pm.expect(['company', 'user', 'system']).to.include(cabin.createdBy.type);",
                  "    });",
                  "    ",
                  "    // Validate type",
                  "    pm.test('Cabin type is passenger', () => {",
                  "        pm.expect(cabin.type).to.equal('passenger');",
                  "    });",
                  "    ",
                  "    // Validate company",
                  "    pm.test('Cabin belongs to correct company', () => {",
                  "        pm.expect(cabin.company).to.equal(pm.environment.get('companyId'));",
                  "    });",
                  "    ",
                  "    console.log('[v0] Passenger cabin created:', cabin._id);",
                  "} else {",
                  "    console.error('[v0] Create failed:', pm.response.text());",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"First Class Cabin\",\n  \"description\": \"Premium passenger cabin with luxury amenities\",\n  \"remarks\": \"High demand during peak season\",\n  \"type\": \"passenger\",\n  \"status\": \"Active\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/cabins",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "cabins"
              ]
            }
          }
        },
        {
          "name": "List Passenger Cabins",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const responseData = pm.response.json();",
                  "    const cabins = responseData.data.cabins;",
                  "    ",
                  "    pm.test('Response contains cabins array', () => {",
                  "        pm.expect(cabins).to.be.an('array');",
                  "    });",
                  "    ",
                  "    pm.test('All cabins are type passenger', () => {",
                  "        cabins.forEach(cabin => {",
                  "            pm.expect(cabin.type).to.equal('passenger');",
                  "        });",
                  "    });",
                  "    ",
                  "    pm.test('All cabins belong to company', () => {",
                  "        cabins.forEach(cabin => {",
                  "            pm.expect(cabin.company).to.equal(pm.environment.get('companyId'));",
                  "        });",
                  "    });",
                  "    ",
                  "    pm.test('Pagination data present', () => {",
                  "        pm.expect(responseData.data).to.have.property('total');",
                  "        pm.expect(responseData.data).to.have.property('page');",
                  "        pm.expect(responseData.data).to.have.property('limit');",
                  "    });",
                  "    ",
                  "    console.log('[v0] Found ' + cabins.length + ' passenger cabins');",
                  "} else {",
                  "    console.error('[v0] List failed:', pm.response.text());",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/cabins?type=passenger&page=1&limit=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "cabins"
              ],
              "query": [
                {
                  "key": "type",
                  "value": "passenger"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
