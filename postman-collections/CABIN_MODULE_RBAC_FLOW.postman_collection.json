    {
      "name": "RBAC TEST CASES",
      "item": [
        {
          "name": "User Without Permission - Create (403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Expect 403 Forbidden', () => {",
                  "    pm.expect(pm.response.code).to.equal(403);",
                  "});",
                  "",
                  "pm.test('Response contains error message', () => {",
                  "    const responseData = pm.response.json();",
                  "    pm.expect(responseData.message || responseData.error).to.exist;",
